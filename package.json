{
  "name": "codemon",
  "displayName": "CodeMon - RPG Observability for Claude Code",
  "description": "A pixel-art RPG skin over real Claude Code agent activity",
  "version": "0.1.0",
  "publisher": "codemon",
  "repository": {
    "type": "git",
    "url": "https://github.com/GneissFrog/codemon.git"
  },
  "bugs": {
    "url": "https://github.com/GneissFrog/codemon/issues"
  },
  "homepage": "https://github.com/GneissFrog/codemon#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "assets/icons/codemon-icon.png",
  "contributes": {
    "commands": [
      {
        "command": "codemon.showGameView",
        "title": "CodeMon: Open Game View"
      },
      {
        "command": "codemon.showBudgetDetails",
        "title": "CodeMon: Show Budget Details"
      },
      {
        "command": "codemon.installHooks",
        "title": "CodeMon: Install Claude Code Hooks"
      },
      {
        "command": "codemon.showSpriteConfig",
        "title": "CodeMon: Open Sprite Configuration"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codemon-sprites",
          "title": "CodeMon Sprites",
          "icon": "assets/icons/codemon-icon.svg"
        }
      ]
    },
    "views": {
      "codemon-sprites": [
        {
          "type": "webview",
          "id": "codemon.spriteConfig",
          "name": "Sprite Configuration"
        },
        {
          "type": "webview",
          "id": "codemon.moduleEditor",
          "name": "Module Editor"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codemon.showGameView",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "configuration": {
      "title": "CodeMon",
      "properties": {
        "codemon.budget.mode": {
          "type": "string",
          "enum": ["tokens", "dollars", "subscription"],
          "default": "subscription",
          "description": "How to track your budget"
        },
        "codemon.budget.dailyTokenLimit": {
          "type": "number",
          "default": 500000,
          "description": "Daily token budget (when mode is 'tokens')"
        },
        "codemon.budget.dailyDollarLimit": {
          "type": "number",
          "default": 10,
          "description": "Daily dollar budget (when mode is 'dollars')"
        },
        "codemon.sprite": {
          "type": "string",
          "enum": ["auto", "knight", "ranger", "rogue", "custom"],
          "default": "auto",
          "description": "Agent sprite (auto assigns based on model)"
        },
        "codemon.sounds.enabled": {
          "type": "boolean",
          "default": false,
          "description": "8-bit sound effects on agent actions"
        },
        "codemon.integration.mode": {
          "type": "string",
          "enum": ["auto", "session-logs", "hooks"],
          "default": "auto",
          "description": "How to receive Claude Code events"
        },
        "codemon.gameView.animations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable walking and idle animations"
        },
        "codemon.gameView.agentWalkingSpeed": {
          "type": "number",
          "default": 0.08,
          "minimum": 0.05,
          "maximum": 0.5,
          "description": "Speed of agent movement between tiles"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/webpack": "^5.28.0",
    "eslint": "^8.54.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {}
}
